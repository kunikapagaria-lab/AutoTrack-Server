# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your cloud server's public URL)
ALLOWED_ORIGINS=http://YOUR_SERVER_IP,https://yourdomain.com
